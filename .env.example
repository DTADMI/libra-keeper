# LibraKeeper Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Google OAuth (Supabase Auth) ─────────────────────────────────
# Configured in Supabase Dashboard: Authentication → Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Database (Local Docker) ────────────────────────────────────
DB_ROOT_USER=libra_admin
DB_ROOT_PASSWORD=your_secure_root_password
DB_APP_USER=libra_app
DB_APP_PASSWORD=your_secure_app_password
DB_NAME=librakeeper
DB_PORT=5433
DB_DATA_DIR=./.postgres_data

# ── Database Connection ───────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
# For Supabase production:
#   Pooled: postgresql://postgres.[ref]:[password]@aws-0-region.pooler.supabase.com:6543/postgres?schema=public
#   Direct: postgresql://postgres.[ref]:[password]@aws-0-region.pooler.supabase.com:5432/postgres?schema=public
DATABASE_URL="postgresql://libra_app:your_secure_app_password@localhost:5433/librakeeper?schema=public"
DIRECT_URL="postgresql://libra_app:your_secure_app_password@localhost:5433/librakeeper?schema=public"

# ── Application URL ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (REQUIRED for Auth, DB, Storage) ──────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis / Upstash ─────────────────────────────────────────────
# Production: KV_REST_API_URL + KV_REST_API_TOKEN (Upstash Redis)
# Local:      REDIS_URL=redis://localhost:6379 (ioredis)
# Neither:    Falls back to in-memory cache (dev/build-safe)
KV_REST_API_URL=
KV_REST_API_TOKEN=
REDIS_URL=

# ── Resend (Email) ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="LibraKeeper <noreply@yourdomain.com>"

# ── Cron Jobs (Vercel) ──────────────────────────────────────────
# Used to secure Vercel Cron endpoints from unauthorized access
CRON_SECRET=

# ── PWA ────────────────────────────────────────────────────────
# Set to "true" to enable PWA features in local development
ENABLE_PWA=false
